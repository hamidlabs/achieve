{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main popup window and the second-monitor break veil",
  "windows": ["main", "veil"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging"
  ]
}
